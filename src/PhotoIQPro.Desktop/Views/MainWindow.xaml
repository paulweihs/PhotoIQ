<Window x:Class="PhotoIQPro.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoIQ Pro" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource MenuBarBrush}" Padding="12,8">
            <Grid>
                <TextBlock Text="📷 PhotoIQ Pro" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                <!-- ═══ Action Buttons (right side) ═══ -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔍 Scan Drives"
                            Command="{Binding ScanDrivesCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,8"
                            Margin="0,0,8,0"/>
                    <Button Content="+ Import"
                            Command="{Binding ImportCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <StackPanel Margin="12">
                <TextBlock Text="LIBRARY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,8,8,4"/>
                <Button Content="🖼 All Photos" Style="{DynamicResource NavButtonStyle}"/>
                <Button Content="⭐ Favorites" Style="{DynamicResource NavButtonStyle}"/>
                <TextBlock Text="AI VIEWS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,16,8,4"/>
                <Button Content="🏷️ Tags" Style="{DynamicResource NavButtonStyle}"/>
                <Button Content="👤 People" Style="{DynamicResource NavButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource ContentBrush}">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="No photos yet" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                    <TextBlock Text="Click Import to add photos or Scan Drives to find them" FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Content="🔍 Scan Drives"
                                Command="{Binding ScanDrivesCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="24,12"
                                Margin="0,0,12,0"/>
                        <Button Content="Import Photos"
                                Command="{Binding ImportCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="24,12"/>
                    </StackPanel>
                </StackPanel>
                <ListBox ItemsSource="{Binding MediaFiles}" SelectedItem="{Binding SelectedMediaFile}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="180" Height="180" Margin="4" Background="{DynamicResource ThumbnailBgBrush}" CornerRadius="4">
                                <Image Source="{Binding ThumbnailMedium}" Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right Sidebar -->
        <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource SidebarBrush}">
            <StackPanel Margin="16" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource ThumbnailBgBrush}" CornerRadius="4" Height="200" Margin="0,0,0,16">
                    <Image Source="{Binding SelectedMediaFile.ThumbnailLarge}" Stretch="Uniform"/>
                </Border>
                <TextBlock Text="{Binding SelectedMediaFile.FileName}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                <TextBlock Text="{Binding SelectedMediaFile.CameraModel}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource StatusBarBrush}" Padding="12,6">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} photos'}" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
