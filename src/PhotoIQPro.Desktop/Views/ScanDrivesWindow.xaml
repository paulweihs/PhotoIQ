<!-- File: PhotoIQPro.Desktop/Views/ScanDrivesWindow.xaml  (FULL REPLACEMENT) -->
<Window x:Class="PhotoIQPro.Desktop.Views.ScanDrivesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhotoIQPro.Desktop.ViewModels"
        Title="Scan Drives for Media"
        Width="850" Height="680"
        MinWidth="700" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E"
        Foreground="#FFCDD6F4">

    <Window.Resources>
        <!-- Brushes -->
        <SolidColorBrush x:Key="SurfaceBrush"  Color="#FF313244"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="#FF45475A"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="SubtextBrush"  Color="#FFA6ADC8"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="GreenBrush"    Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="RedBrush"      Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="YellowBrush"   Color="#FFF9E2AF"/>
        <SolidColorBrush x:Key="MangosBrush"   Color="#FFFAB387"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"
                                   Padding="{TemplateBinding Padding}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu style -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title ═══ -->
        <TextBlock Grid.Row="0"
                   Text="Scan Drives for Photos &amp; Videos"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,16"/>

        <!-- ═══ TabControl ═══ -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ─── Tab 1: Drives ─── -->
            <TabItem Header="Drives">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Select drives to scan:"
                               Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Drives}"
                             Background="{StaticResource SurfaceBrush}"
                             BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,6">
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                                        <TextBlock Text="{Binding SizeInfo}" Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button Grid.Row="2" Content="↻ Refresh Drives"
                            Command="{Binding RefreshDrivesCommand}"
                            Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="0,6,0,0"/>
                </Grid>
            </TabItem>

            <!-- ─── Tab 2: Exclusions ─── -->
            <TabItem Header="Exclusions">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,0,0,8"
                               TextWrapping="Wrap">
                        <Run Text="Type a folder name (e.g. &quot;AppData&quot;) to exclude everywhere, or a full path (e.g. &quot;D:\Temp\Junk&quot;) to exclude one specific folder."/>
                    </TextBlock>

                    <!-- Text input + Add -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource Surface2Brush}"
                                 Padding="8,6" FontSize="13" VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddExclusionCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Add"
                                Command="{Binding AddExclusionCommand}"
                                Style="{StaticResource ActionButton}" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Browse button -->
                    <Button Grid.Row="2" Content="📁 Browse for folder..."
                            Command="{Binding BrowseForExclusionCommand}"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8" Padding="12,6"/>

                    <!-- Exclusion list -->
                    <ListBox Grid.Row="3" ItemsSource="{Binding ExcludedFolders}"
                             Background="{StaticResource SurfaceBrush}"
                             BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TypeLabel}"
                                               Foreground="{StaticResource SubtextBrush}"
                                               FontSize="10" VerticalAlignment="Center"
                                               MinWidth="65" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="3" Content="✕"
                                            Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Foreground="{StaticResource RedBrush}"
                                            Background="Transparent" BorderThickness="0"
                                            FontSize="12" Cursor="Hand" Padding="6,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button Grid.Row="4" Content="↻ Reset to Defaults"
                            Command="{Binding ResetExclusionsCommand}"
                            Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="0,6,0,0"/>
                </Grid>
            </TabItem>

            <!-- ─── Tab 3: Results ─── -->
            <TabItem Header="Results">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Summary cards -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12"
                                Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalPhotos}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                                <TextBlock Text="Photos" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalVideos}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Videos" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalRaw}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MangosBrush}"/>
                                <TextBlock Text="RAW" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalSizeDisplay}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource YellowBrush}"/>
                                <TextBlock Text="Total Size" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="{Binding ScanDuration}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Duration" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Toolbar: Select/Deselect + Sort -->
                    <Grid Grid.Row="1" Margin="0,0,0,6"
                          Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Select All" Command="{Binding SelectAllFoldersCommand}"
                                    Style="{StaticResource LinkButton}" Margin="0,0,12,0"/>
                            <Button Content="Deselect All" Command="{Binding DeselectAllFoldersCommand}"
                                    Style="{StaticResource LinkButton}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Sort:" Foreground="{StaticResource SubtextBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            
                        </StackPanel>
                    </Grid>

                    <!-- Folder list with checkboxes + right-click context menu -->
                    <ListBox x:Name="_resultsListBox" Grid.Row="2"
                             Tag="{Binding DataContext, RelativeSource={RelativeSource Self}}"
                             ItemsSource="{Binding ResultFoldersView}"
                             Background="{StaticResource SurfaceBrush}"
                             BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" Padding="4"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Right-click context menu -->
                                    <Grid.ContextMenu>
                                        <ContextMenu Background="#FF313244" Foreground="#FFCDD6F4" BorderBrush="#FF45475A" BorderThickness="1"
                 DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Exclude this folder"
                  Command="{Binding ExcludeFolderCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Exclude all folders with this name"
                  Command="{Binding ExcludeFolderByNameCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FolderPath}"
                                               Foreground="{StaticResource TextBrush}" FontSize="12"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FileCount, StringFormat='{}{0} files'}"
                                               Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}"
                                               Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               MinWidth="60" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Import button -->
                    <Button Grid.Row="3" Content="Import Selected Folders"
                            Command="{Binding ImportSelectedCommand}"
                            Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Right" Margin="0,10,0,0" Padding="20,10"
                            Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    <TextBlock Text="{Binding ProgressDetail}" Foreground="{StaticResource SubtextBrush}"
                               FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FoldersScanned, StringFormat='{}{0:N0} folders'}"
                               Foreground="{StaticResource SubtextBrush}" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding FilesFound, StringFormat='{}{0:N0} files'}"
                               Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Bottom Buttons ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Cancel Scan" Command="{Binding CancelScanCommand}"
                    Style="{StaticResource ActionButton}" Foreground="{StaticResource RedBrush}"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Start Scan" Command="{Binding StartScanCommand}"
                        Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                <Button Content="Close" Click="OnCloseClick" Style="{StaticResource ActionButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
